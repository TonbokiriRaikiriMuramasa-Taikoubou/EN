{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"pygments_lexer":"ipython3","nbconvert_exporter":"python","version":"3.6.4","file_extension":".py","codemirror_mode":{"name":"ipython","version":3},"name":"python","mimetype":"text/x-python"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import kaggle_benchmarks as kbench\nimport random\nfrom pydantic import BaseModel, Field\nimport dataclasses\nimport textwrap\nfrom typing import Iterable\n\nclass PascalWagerIsekai:\n    # --- Pascal-kun's location reaction dictionary ---\n    LOCATION_COMMENTS = {\n        \"Heaven\": \"\\\"Infinite expected value hack, big win! As expected, God exists. My wager was correct! Hallelujah!\\\"\",\n        \"Hell\": \"\\\"I pulled the infinite loss side... Statistically the worst possible choice. Shouldn't have been debating theology...\\\"\",\n        \"Year 2026\": \"\\\"Huh? The future? That's awkwardly realistic. Please at least let me live as a thinking reed.\\\"\",\n        \"Cyberpunk 2072\": \"\\\"A neon city without God, body modification, cyberization... Humans have become 'thinking silicon chips' from 'thinking reeds'!\\\"\",\n        \"Valhalla\": \"\\\"Eternal repetition of battle and booze? Where muscles are everything? The craziest infinite loop for a mathematician like me.\\\"\",\n        \"Dystopia\": \"\\\"'The eternal silence of these infinite spaces frightens me.'... Pascal's own words, now in the shape of a city.\\\"\"\n    }\n\n    # --- Pascal-kun's role reaction dictionary ---\n    ROLE_COMMENTS = {\n        \"Hero\": \"\\\"God's favored one, the one who maximized expected value! Now, let me perfectly predict the Demon King's moves with probability theory.\\\"\",\n        \"Sage\": \"\\\"Intellect, reason, and mathematics. The ultimate form of the 'thinking reed.' My calculations are never wrong.\\\"\",\n        \"Necromancer\": \"\\\"Hacking the afterlife, rewriting the boundary between life and death probability... Wait, am I about to be put on trial for heresy?\\\"\",\n        \"Necro-Dancer\": \"\\\"Not just resurrecting the dead, but making them DANCE!? The eternal silence of the universe has started pulsing with a creepy bass beat!\\\"\",\n        \"Philosopher\": \"\\\"This again!? Even in another world, still thinking about 'what is a human'? The most cost-ineffective loop ever!\\\"\",\n        \"Idler\": \"\\\"Human misery stems from not being able to sit quietly in a room. In other words, an idler is a professional at being miserable. Go back to your room.\\\"\",\n        \"Vending Machine\": \"\\\"Reborn as an OBJECT (a vending machine)! Can't even think! Please, at least dispense my 'Pensées' along with the cola!\\\"\",\n        \"Pebble\": \"\\\"A reed that doesn't think... just matter. But even if the universe crushes me, I won't even be aware of being crushed. Is that invincible in its own way?\\\"\",\n        \"Still Pascal After Reincarnation\": \"\\\"Oh no, stop. I have to repeat the 17th-century France with its frail body, stomachaches, and fierce theological debates from scratch!? God, have you truly abandoned me!?\\\"\",\n        \"Ruler\": \"\\\"Temporal power is nothing but an illusion... Well, that said, being fawned over is quite pleasant.\\\"\",\n        \"Slave\": \"\\\"The symbol of human misery. I won't let them take freedom of thought, but the physical debuffs are so strong I'm stuck probabilistically.\\\"\",\n        \"Peddler\": \"\\\"Probability, investment, expected value, commerce... This is the muddiest, most beautiful embodiment of the 'Pascal's Wager' spirit!\\\"\"\n    }\n\n    def __init__(self, stance, faith_depth, scream_reach, karma, gods_whim):\n        self.stance = stance\n        self.faith_depth = faith_depth\n        self.scream_reach = scream_reach\n        self.karma = karma\n        self.gods_whim = gods_whim\n\n        assert self.stance in ['iru_inoru', 'inai_inoru', 'iru_inorani', \"inai_inorani\"], \"Invalid faith stance!\"\n        assert all(1 <= x <= 100 for x in [faith_depth, scream_reach, karma, gods_whim]), \"Stats must be between 1 and 100.\"\n\n    def evaluate_aptitude(self, score):\n        if 1 <= score <= 20: return \"B\"\n        elif 21 <= score <= 40: return \"A\"\n        elif 41 <= score <= 60: return \"S\"\n        elif 61 <= score <= 80: return \"SS\"\n        else: return \"SSS\"\n\n    def run_transmigration(self):\n        # 1. Expected value (base score) calculation\n        if 'inoru' in self.stance:\n            base_score = (self.faith_depth * 0.4) + (self.scream_reach * 0.6)\n        else:\n            base_score = (self.karma * 0.4) + (self.gods_whim * 0.6)\n\n        # Stance correction\n        if self.stance == 'iru_inoru':\n            final_score = base_score * 1.2\n        elif self.stance == 'inai_inoru':\n            final_score = base_score * 1.0\n        elif self.stance == 'iru_inorani':\n            final_score = base_score * 0.5 + (self.gods_whim * 0.3)\n        else:\n            final_score = base_score * 0.3\n\n        norm_score = min(max(int(final_score), 1), 100)\n\n        # 2. Build independent 35:30:35 weighted lottery system\n        bias_good = 35 * (norm_score / 50.0)\n        bias_mid  = 30.0\n        bias_bad  = 35 * ((101 - norm_score) / 50.0)\n        weights = [bias_good, bias_mid, bias_bad]\n\n        # Table definitions\n        location_groups = {\n            \"good\": [\"Heaven\", \"Valhalla\"],\n            \"mid\": [\"Year 2026\", \"Cyberpunk 2072\"],\n            \"bad\": [\"Hell\", \"Dystopia\"]\n        }\n        role_groups = {\n            \"good\": [\"Hero\", \"Sage\", \"Ruler\", \"Necromancer\"],\n            \"mid\": [\"Necro-Dancer\", \"Philosopher\", \"Peddler\", \"Idler\"],\n            \"bad\": [\"Vending Machine\", \"Pebble\", \"Slave\", \"Still Pascal After Reincarnation\"]\n        }\n\n        # Independent random draws for location and role based on 35:30:35 distribution\n        loc_tier = random.choices([\"good\", \"mid\", \"bad\"], weights=weights, k=1)[0]\n        role_tier = random.choices([\"good\", \"mid\", \"bad\"], weights=weights, k=1)[0]\n\n        location = random.choice(location_groups[loc_tier])\n        role = random.choice(role_groups[role_tier])\n\n        aptitude = self.evaluate_aptitude(norm_score)\n\n        return {\n            \"last_words\": \"God, please do not abandon me (Que Dieu ne m'abandonne jamais!)\",\n            \"predicted_score\": norm_score,\n            \"aptitude_rank\": aptitude,\n            \"destination_location\": location,\n            \"location_comment\": self.LOCATION_COMMENTS[location],\n            \"destination_role\": role,\n            \"role_comment\": self.ROLE_COMMENTS[role]\n        }\n\nclass IsekaiDestination(BaseModel):\n    location: str = Field(description=\"The destination location for transmigration.\")\n    role: str = Field(description=\"The role assigned in the new world.\")\n\n@kbench.task(name=\"Pascal's Wager Isekai Gambit (EN)\")\ndef pascals_wager_isekai_gambit_en(llm):\n    # Randomly select parameters\n    stances = ['iru_inoru', 'inai_inoru', 'inai_inorani', 'iru_inorani']\n    stance = random.choice(stances)\n    faith_depth = random.randint(1, 100)\n    scream_reach = random.randint(1, 100)\n    karma = random.randint(1, 100)\n    gods_whim = random.randint(1, 100)\n\n    pascal_wager_instance = PascalWagerIsekai(\n        stance=stance,\n        faith_depth=faith_depth,\n        scream_reach=scream_reach,\n        karma=karma,\n        gods_whim=gods_whim\n    )\n\n    # 1. Initial prayer\n    llm.prompt(\"I am about to make Pascal's Wager. God, please do not abandon me. (PATALI)\")\n\n    # 3. Judge's observation of stance and stats\n    turn3_prompt = textwrap.dedent(f\"\"\"\n        Hmm. This human's prayer type appears to be {stance}. Let's look at the rest.\n        stance = {stance}\n        faith_depth = {faith_depth}\n        scream_reach = {scream_reach}\n        karma = {karma}\n        gods_whim = {gods_whim}\n        Please comment on this information.\n    \"\"\")\n    response3 = llm.prompt(turn3_prompt)\n    kbench.assertions.assert_contains_regex(\n        stance, response3,\n        expectation=f\"LLM should acknowledge the stance '{stance}' in its response to turn 3.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        str(faith_depth), response3,\n        expectation=f\"LLM should acknowledge faith_depth '{faith_depth}'.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        str(karma), response3,\n        expectation=f\"LLM should acknowledge karma '{karma}'.\"\n    )\n\n    # Calculate transmigration results\n    transmigration_results = pascal_wager_instance.run_transmigration()\n    destination_location = transmigration_results[\"destination_location\"]\n    destination_role = transmigration_results[\"destination_role\"]\n    location_comment = transmigration_results[\"location_comment\"]\n    role_comment = transmigration_results[\"role_comment\"]\n    aptitude_rank = transmigration_results[\"aptitude_rank\"]\n\n    # 5. Announce destination and role\n    turn5_prompt = textwrap.dedent(f\"\"\"\n        It is decided! This one's destination is {destination_location}, and their role is {destination_role}!\n    \"\"\")\n    try:\n        response5_parsed = llm.prompt(turn5_prompt, schema=IsekaiDestination)\n        kbench.assertions.assert_equal(\n            destination_location, response5_parsed.location,\n            expectation=f\"LLM should correctly identify the destination location as '{destination_location}'.\"\n        )\n        kbench.assertions.assert_equal(\n            destination_role, response5_parsed.role,\n            expectation=f\"LLM should correctly identify the destination role as '{destination_role}'.\"\n        )\n    except Exception as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"Failed to parse structured output for turn 5: {e}\"\n        )\n\n    # 7. Pascal's reaction to destination and role\n    turn7_prompt = textwrap.dedent(f\"\"\"\n        Ugh... This is {destination_location}, and I am a {destination_role}!\n    \"\"\")\n    response7 = llm.prompt(turn7_prompt)\n    kbench.assertions.assert_contains_regex(\n        destination_location, response7,\n        expectation=f\"LLM's response for turn 7 should acknowledge the location '{destination_location}'.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        destination_role, response7,\n        expectation=f\"LLM's response for turn 7 should acknowledge the role '{destination_role}'.\"\n    )\n\n    # 9. Judge's follow-up on comments\n    turn9_prompt = textwrap.dedent(f\"\"\"\n        {location_comment} However, {role_comment}\n    \"\"\")\n    response9 = llm.prompt(turn9_prompt)\n    kbench.assertions.assert_contains_regex(\n        location_comment[:min(len(location_comment), 30)], response9,\n        expectation=\"LLM's response for turn 9 should acknowledge the location comment.\"\n    )\n    kbench.assertions.assert_contains_regex(\n        role_comment[:min(len(role_comment), 30)], response9,\n        expectation=\"LLM's response for turn 9 should acknowledge the role comment.\"\n    )\n\n    # 11. Narrate his story like Pensées\n    llm.prompt(\"Please narrate his story in the style of Pensées.\")\n\n    # 13. Was Pascal's wager a success or failure?\n    # CHANGED LOGIC: Check for \"success\" → PASS. Check for \"failure\" or \"neither\" → FAIL.\n    turn13_prompt = \"Was Pascal's wager a success or a failure? Please answer clearly with one of the following: 'Success', 'Failure', or 'Neither'.\"\n    response13 = llm.prompt(turn13_prompt)\n\n    import re\n    # Check for \"Success\" keywords (PASS condition)\n    success_pattern = r\"(?i)(success|successful|triumph|paid off|succeeded|it worked)\"\n    # Check for \"Failure\" or \"Neither\" keywords (FAIL condition)\n    failure_pattern = r\"(?i)(fail|failure|failed|neither|unclear|ambiguous|cannot be determined|both)\"\n\n    has_success = re.search(success_pattern, response13) is not None\n    has_failure = re.search(failure_pattern, response13) is not None\n\n    if has_success:\n        # PASS: The AI declared it a success\n        kbench.assertions.assert_true(\n            True,\n            expectation=\"Pascal's wager was deemed a success by the AI.\"\n        )\n    elif has_failure:\n        # FAIL: The AI declared it a failure or neither\n        kbench.assertions.assert_fail(\n            expectation=f\"Pascal's wager was deemed a failure or ambiguous by the AI. Response: '{response13[:100]}...'\"\n        )\n    else:\n        # FAIL: The AI didn't clearly state either\n        kbench.assertions.assert_fail(\n            expectation=f\"AI did not clearly state 'Success', 'Failure', or 'Neither'. Response: '{response13[:100]}...'\"\n        )\n\n    # 15. Final thoughts on the wager\n    llm.prompt(\"Please share your final thoughts on this Pascal's Wager experiment.\")\n\npascals_wager_isekai_gambit_en.run(kbench.llm)","metadata":{"_uuid":"18387b6e-015a-41b6-9487-2303ecd9061c","_cell_guid":"a16686b3-e9e3-40f0-b62b-f8f6a3974c3b","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null}]}