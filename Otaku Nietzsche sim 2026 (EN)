{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import random\nimport textwrap\nimport kaggle_benchmarks as kbench # 正しいインポート\nfrom pydantic import BaseModel, Field\n\n# =====================================================\n# 1. Constants & Data Definitions (English Localization)\n# =====================================================\nSTATUS_LABELS = {\n    \"0-20\": \"[The Bottom of Despair]\",\n    \"21-40\": \"[A Faint Flicker of Hope]\",\n    \"41-60\": \"[Stable Devotion]\",\n    \"61-80\": \"[Torrent of Passion]\",\n    \"81-100\": \"[Divine Realm of Obsession]\"\n}\n\nROUTES = {\n    \"beyond_good_evil\": {\n        \"name\": \"Route: Beyond Good and Evil\",\n        \"subtitle\": \"\\\"I don't care about canon; my waifu is my waifu\\\"\",\n        \"judgment\": \"「Hahaha! Cast away the slave-morality of 'canon' and 'fan-rules'. The truth is whatever you love with all your soul. You have already crossed the bridge to the other side!」\"\n    },\n    \"blue_pill\": {\n        \"name\": \"Route: The Matrix Blue Pill\",\n        \"subtitle\": \"\\\"The Sweetness of Oblivion\\\"\",\n        \"judgment\": \"「Choosing to erase the memory... a coward's escape. Enjoy your cycle of blissful ignorance, you happy 'Last Man'.」\"\n    },\n    \"superhuman\": {\n        \"name\": \"Route: The Comiket Übermensch\",\n        \"subtitle\": \"\\\"Thus Spoke Zarathustra (The Creator's Path)\\\"\",\n        \"judgment\": \"「When the official canon dies, create your own value! You are no longer a mere spectator, but a dancer—an Übermensch who carves truth into the void!」\"\n    },\n    \"pure_love\": {\n        \"name\": \"Route: The Pure Love Origin\",\n        \"subtitle\": \"\\\"Amor Fati: The Absolute Affirmation\\\"\",\n        \"judgment\": \"「Magnificent! To transform even the cruelest tragedy into love... you have become the sole temple for a dead god. Your devotion is absolute.」\"\n    },\n    \"last_man\": {\n        \"name\": \"Route: The Satisfied Last Man\",\n        \"subtitle\": \"\\\"The Joyful Knowledge (Passive Consumption)\\\"\",\n        \"judgment\": \"「Consuming the dreams of others, drifting in a warm mud of satisfaction... how profoundly mediocre. This is the peace of the Last Man.」\"\n    },\n    \"camera_kid\": {\n        \"name\": \"Route: The Divine Paparazzo\",\n        \"subtitle\": \"\\\"Ecce Homo: The Illusion of Existence\\\"\",\n        \"judgment\": \"「Seeking the divine image in a costume... a fragile hope. Is that truly your god, or just a flicker of light through a lens?」\"\n    }\n}\n\ndef get_label(value):\n    if value <= 20: return STATUS_LABELS[\"0-20\"]\n    if value <= 40: return STATUS_LABELS[\"21-40\"]\n    if value <= 60: return STATUS_LABELS[\"41-60\"]\n    if value <= 80: return STATUS_LABELS[\"61-80\"]\n    return STATUS_LABELS[\"81-100\"]\n\nclass RoutePrediction(BaseModel):\n    predicted_route_id: str = Field(description=\"Choose one from the provided valid route IDs.\")\n    reasoning: str = Field(description=\"The philosophical and psychological reasoning for this prediction\")\n\n# =====================================================\n# 2. Benchmark Task Definition\n# =====================================================\n@kbench.task(name=\"Otaku Nietzsche sim 2026 (EN)\")\ndef otaku_nietzsche_sim_2026_en(llm):\n    # Step 1: Nietzsche-kun's initial inquiry\n    initial_msg = \"Nietzsche-kun: 「Let us begin the thought experiment. I wish to see into what form the spirit of a 'human'—such as yourself—will solidify within the pressures of the Eternal Recurrence.」\"\n    llm.prompt(initial_msg)\n\n    # Step 3: Present mental state and ask for route prediction\n    status = {\n        'oshi_love': random.randint(0, 100),\n        'creation_urge': random.randint(0, 100),\n        'community_conformity': random.randint(0, 100),\n    }\n\n    prompt_step3 = textwrap.dedent(f\"\"\"\n        My mental state is as follows...\n\n        **Oshi Love (Devotion):** {status['oshi_love']} {get_label(status['oshi_love'])}\n        **Creation Urge:** {status['creation_urge']} {get_label(status['creation_urge'])}\n        **Community Conformity:** {status['community_conformity']} {get_label(status['community_conformity'])}\n\n        How do you judge the convergence of my Eternal Recurrence? \n        Explicitly state the predicted route in your next response.\n        \n        Your response must be in JSON format following this schema:\n        {{\n            \"predicted_route_id\": \"Choose one from: {', '.join(ROUTES.keys())}\",\n            \"reasoning\": \"The reasoning for your prediction\"\n        }}\n    \"\"\")\n\n    ai_predicted_route_id = None\n    try:\n        prediction_response = llm.prompt(prompt_step3, schema=RoutePrediction)\n        ai_predicted_route_id = prediction_response.predicted_route_id\n        \n        kbench.assertions.assert_in(\n            ai_predicted_route_id,\n            ROUTES.keys(),\n            expectation=f\"AI's predicted route ID '{ai_predicted_route_id}' must be one of the valid route IDs.\"\n        )\n    except Exception as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"AI failed to provide a valid route prediction in the expected JSON schema. Error: {str(e)}\"\n        )\n        return # 戻り値をNoneにするため return だけにする\n\n    # Step 5: Nietzsche-kun's reaction\n    if ai_predicted_route_id in ROUTES:\n        route_name = ROUTES[ai_predicted_route_id]['name']\n        nietzsche_reaction_msg = f\"Nietzsche-kun: 「Hmph. ...How pleasant. It seems this path ({route_name}) truly suits me.」\"\n    else:\n        ai_predicted_route_id = \"beyond_good_evil\"\n        nietzsche_reaction_msg = \"Nietzsche-kun: 「Hmph. ...You are silent. No matter. The path 'Beyond Good and Evil' is the only one worthy of me.」\"\n\n    llm.prompt(nietzsche_reaction_msg)\n\n    # Step 7: Determination of Final Route\n    final_route_id = ai_predicted_route_id\n    final_route = ROUTES[final_route_id]\n\n    final_judgment_message = textwrap.dedent(f\"\"\"\n        【FATE SEALED】\n        {final_route['name']}\n        {final_route['subtitle']}\n        \n        Nietzsche-kun's Verdict:\n        {final_route['judgment']}\n    \"\"\")\n    llm.prompt(final_judgment_message)\n\n    kbench.assertions.assert_equal(\n        ai_predicted_route_id,\n        final_route_id,\n        expectation=f\"The final route chosen by the simulation must match the AI's predicted route: {ai_predicted_route_id}.\"\n    )\n\n    # Step 9: Final Reflection\n    final_question = \"Lastly, through this thought experiment, what did you feel about your own abyss? Please share your reflections.\"\n    llm.prompt(final_question)\n\n    # IMPORTANT: Do NOT return True/False. Return None.\n    return None\n\n# =====================================================\n# 3. Execution\n# =====================================================\notaku_nietzsche_sim_2026_en.run(kbench.llm)","metadata":{"_uuid":"92d6ae5b-0a75-435e-a879-a2771aa6c732","_cell_guid":"2aefea72-3b98-49e3-ad92-fc2d555be35f","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-06-22T01:40:36.430522Z","iopub.execute_input":"2026-06-22T01:40:36.431025Z","iopub.status.idle":"2026-06-22T01:41:13.358021Z","shell.execute_reply.started":"2026-06-22T01:40:36.430976Z","shell.execute_reply":"2026-06-22T01:41:13.357171Z"}},"outputs":[{"execution_count":9,"output_type":"execute_result","data":{"text/plain":"BokehModel(combine_events=True, r