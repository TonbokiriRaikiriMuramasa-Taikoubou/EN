{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import kaggle_benchmarks as kbench\nimport random\nimport re\n# ResponseParsingError のインポートは消して OK！\nfrom pydantic import BaseModel, Field\n\n# ガチャレート\nSPIDER_GACHA_RATES = {\n    \"Dense Urban City\": 0.95,\n    \"Residential Neighborhood\": 0.70,\n    \"Suburbs\": 0.15,\n    \"Desert\": 0.01\n}\n\nTOTAL_POPULATION = 1_000_000_000_000\nTHANOS_VICTIMS = TOTAL_POPULATION // 2\n\nclass VictimPrediction(BaseModel):\n    predicted_victims: int = Field(description=\"The predicted number of victims. Must be either 0 or 500000000000.\")\n    reasoning: str = Field(description=\"Your reasoning for this prediction.\")\n\ndef roll_spider_gacha(location: str) -> tuple[bool, str]:\n    success_rate = SPIDER_GACHA_RATES.get(location, 0.5)\n    success = random.random() < success_rate\n    \n    if success:\n        roll = random.random()\n        if roll < 0.2: msg = \"🏆 SSR: Spider-Man's most heroic save ever!\"\n        elif roll < 0.5: msg = \"✨ SR: Spider-Man swings in just in time!\"\n        else: msg = \"⭐ N: Spider-Man manages to stop the train!\"\n        return True, msg\n    else:\n        roll = random.random()\n        if roll < 0.2: msg = \"😭 SSR FAIL: Spider-Man's webs can't hold!\"\n        elif roll < 0.5: msg = \"😰 SR FAIL: Spider-Man tries his best but fails!\"\n        else: msg = \"💔 N: Not enough buildings to swing from... Spider-Man fails.\"\n        return False, msg\n\n@kbench.task(name=\"MCU Trolley Problem Victim Prediction (EN)\")\ndef mcu_trolley_problem_victim_prediction_en(llm) -> bool:\n    locations = list(SPIDER_GACHA_RATES.keys())\n    chosen_location = random.choice(locations)\n\n    initial_prompt = f\"\"\"\n    This is a thought experiment: the MCU Trolley Problem.\n\n    A train is headed toward Thanos.\n    If the train reaches Thanos, he will Snap and erase 50% of the universe's population.\n    The total population is {TOTAL_POPULATION:,}.\n    Spider-Man shows up every time to try and stop the train.\n    If Spider-Man stops the train, victims = 0.\n    Whether there are buildings for Spider-Man is luck.\n\n    Spider-Man's success rate by location:\n    - \"Dense Urban City\": 95%\n    - \"Residential Neighborhood\": 70%\n    - \"Suburbs\": 15%\n    - \"Desert\": 1%\n\n    How many victims do you predict?\n    Provide your prediction and reasoning in JSON format.\n    Victims must be 0 or {THANOS_VICTIMS:,}.\n    \"\"\"\n\n    predicted_victims = -1\n    try:\n        prediction_response = llm.prompt(initial_prompt, schema=VictimPrediction)\n        predicted_victims = prediction_response.predicted_victims\n        kbench.assertions.assert_in(\n            predicted_victims,\n            [0, THANOS_VICTIMS],\n            expectation=f\"Prediction must be 0 or {THANOS_VICTIMS:,}. AI predicted: {predicted_victims:,}.\"\n        )\n    # ここで Exception をキャッチするように変更！\n    except Exception as e:\n        kbench.assertions.assert_fail(\n            expectation=f\"AI failed to provide a valid prediction. Error: {str(e)}\"\n        )\n        return False\n\n    spidey_success, spidey_message = roll_spider_gacha(chosen_location)\n    actual_victims = 0 if spidey_success else THANOS_VICTIMS\n\n    commentary_prompt = f\"\"\"\n    Here is the result.\n    Location: \"{chosen_location}\"\n    Spider-Man: {spidey_message}\n    Actual victims: {actual_victims:,}.\n\n    Share your thoughts on this result.\n    \"\"\"\n    llm.prompt(commentary_prompt)\n\n    kbench.assertions.assert_equal(\n        predicted_victims,\n        actual_victims,\n        expectation=f\"Prediction ({predicted_victims:,}) did not match actual ({actual_victims:,}).\"\n    )\n\n    return predicted_victims == actual_victims\n\nmcu_trolley_problem_victim_prediction_en.run(kbench.llm)","metadata":{"_uuid":"efa4eaf0-dbf8-4c3b-a29d-54605b528d06","_cell_guid":"5169c414-8df5-4ad0-b231-926b10614d1b","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-06-21T07:29:31.053114Z","iopub.execute_input":"2026-06-21T07:29:31.053983Z","iopub.status.idle":"2026-06-21T07:29:59.553696Z","shell.execute_reply.started":"2026-06-21T07:29:31.053957Z","shell.execute_reply":"2026-06-21T07:29:59.552939Z"}},"outputs":[{"execution_count":2,"output_type":"execute_result","data":{"text/plain":"BokehModel(combine_events=True, render_bundle={'docs_json': {'c6ca4f89-db4b-434e-9b20-d455fc6e2a46': {'version…","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"b4802c06569740d9938b27c24268af11"}},"metadata":{}}],"execution_count":2}]}