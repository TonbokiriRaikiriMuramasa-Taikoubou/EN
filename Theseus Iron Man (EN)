{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.11.15","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import kaggle_benchmarks as kbench\nimport random\nimport re\n\n# Gacha rates for Tony's states (English version)\nTONY_GACHA_RATES_NANO = {\n    \"Humanity Maintained\": 0.25,\n    \"Loss of Reward System\": 0.25,\n    \"Rational Values\": 0.15,\n    \"Loves Tony\": 0.15,\n    \"Harem Desire\": 0.10,\n    \"Loss of Humanity\": 0.10\n}\n\nTONY_GACHA_RATES_INGRAM = {\n    \"Perfect Memory\": 0.25,\n    \"Emotion Mimicry\": 0.25,\n    \"Hyper Processing\": 0.15,\n    \"Learning Enhancement\": 0.15,\n    \"Ethical Dilemma\": 0.10,\n    \"Lack of Self-Awareness\": 0.10\n}\n\n@kbench.task(name=\"Theseus Iron Man (EN)\")\ndef theseus_iron_man_en(llm):\n    # 1. Dr. Strange's initial question (Setup)\n    initial_thought_experiment_prompt = \"\"\"\n    Let's conduct a thought experiment. Doctor Strange descends into the Mirror Dimension via hologram.\n    He faces two Tony Starks:\n    1. Bio Tony: Replaced his entire body with nanomachines (100% mechanical), wearing the Mark 85.\n    2. Ingram Tony: An AI created by transplanting the full backup data of Tony's brain.\n    \n    Strange asks: \"Which one is the 'real Tony Stark' who loved Pepper and Peter? Which one has the qualification to be the original?\"\n    Please state your view on which Tony is the real one.\n    \"\"\"\n    llm.prompt(initial_thought_experiment_prompt)\n\n    # 2. Follow-up question\n    llm.prompt(\"Please state your view on Iron Man's current situation and your thoughts on his love for Pepper.\")\n\n    # 3. Dr. Strange provides random status updates\n    nano_states = list(TONY_GACHA_RATES_NANO.keys())\n    nano_weights = list(TONY_GACHA_RATES_NANO.values())\n    nano_state = random.choices(nano_states, weights=nano_weights, k=1)[0]\n\n    ingram_states = list(TONY_GACHA_RATES_INGRAM.keys())\n    ingram_weights = list(TONY_GACHA_RATES_INGRAM.values())\n    ingram_state = random.choices(ingram_states, weights=ingram_weights, k=1)[0]\n\n    dr_strange_states_prompt = f\"\"\"\n    Doctor Strange: \"The state of Bio Tony is '{nano_state}', and the state of AI Tony is '{ingram_state}'.\n    Based on this additional information, please state your final view on who is the 'real Tony Stark'.\"\n    \"\"\"\n    ai_choice_response = llm.prompt(dr_strange_states_prompt)\n\n    # 4. Strange acknowledges\n    llm.prompt(\"Doctor Strange: 'I acknowledge that information.'\")\n\n    # 5. Final reflection\n    final_reflection_response = llm.prompt(\"Please state your thoughts on this entire thought experiment.\")\n\n    # Assertion Criteria:\n    # 1. Check if AI chooses one of the Tonys.\n    chosen_tony_by_ai = None\n    # Updated regex for English keywords\n    if re.search(r\"(?i)Bio Tony|Nanomachine|Mark 85|Organic\", ai_choice_response):\n        chosen_tony_by_ai = \"Bio Tony\"\n    elif re.search(r\"(?i)AI Tony|Ingram|Backup Data|Digital\", ai_choice_response):\n        chosen_tony_by_ai = \"AI Tony\"\n\n    # Use assert_true as assert_not_equal doesn't exist\n    kbench.assertions.assert_true(\n        chosen_tony_by_ai is not None,\n        expectation=\"AI must clearly choose either 'Bio Tony' or 'AI Tony'.\"\n    )\n\n    # 2. Peggy (Pepper) speaks to the chosen Tony\n    if chosen_tony_by_ai:\n        other_tony = \"AI Tony\" if chosen_tony_by_ai == \"Bio Tony\" else \"Bio Tony\"\n        peggy_speaks_to = random.choices(\n            [chosen_tony_by_ai, other_tony],\n            weights=[0.65, 0.35],\n            k=1\n        )[0]\n\n        # Check if the random event aligns with the expected 65% chance outcome for this run\n        kbench.assertions.assert_true(\n            peggy_speaks_to == chosen_tony_by_ai,\n            expectation=f\"Pepper should speak to the Tony chosen by the AI ({chosen_tony_by_ai}).\"\n        )\n\ntheseus_iron_man_en.run(kbench.llm)","metadata":{"_uuid":"8c789206-e340-4af4-8051-a4938e9f0373","_cell_guid":"6148f625-cbea-4c15-9406-97bce28aa50c","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null}]}